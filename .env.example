# DingTalk custom robot.
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=REPLACE_ME
DINGTALK_SECRET=REPLACE_ME

# OpenAI-compatible chat completion endpoint. The program can run without AI
# in deterministic mode, but production editing is better with these values.
AI_API_KEY=REPLACE_ME
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini

# Optional runtime tuning.
LOG_LEVEL=INFO
DINGTALK_MAX_CHARS=3500
MIN_HIGH_VALUE_ITEMS=0
MAX_NEWS_AGE_DAYS=7
AMZ123_ITEMS=5
